<section class="hero-section">
  <div class="hero-content">
    {% if section.settings.eyebrow != blank %}
      <span class="badge">{{ section.settings.eyebrow }}</span>
    {% endif %}

    {% if section.settings.heading != blank %}
      <h1>{{ section.settings.heading }}</h1>
    {% endif %}

    {% if section.settings.text != blank %}
      <p>{{ section.settings.text }}</p>
    {% endif %}

    {% if section.settings.button_label != blank %}
      <a class="primary-button" href="{{ section.settings.button_link }}">{{ section.settings.button_label }}</a>
    {% endif %}
  </div>

  <div class="hero-visual">
    <div class="floating-card card-one">Envío directo</div>
    <div class="floating-card card-two">Ofertas limitadas</div>
    <div class="premium-card">
      <div class="glow"></div>
      <h2>Top Pick</h2>
      <p>Organización, ambiente y bienestar para tu hogar.</p>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "MS100 Hero",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Texto superior", "default": "Dropshipping store · Smart picks" },
    { "type": "text", "id": "heading", "label": "Título", "default": "Haz tu casa más cómoda, organizada y visual en minutos." },
    { "type": "textarea", "id": "text", "label": "Texto", "default": "Productos prácticos de hogar, relax y cocina pensados para compras rápidas, regalos útiles y rutinas diarias más simples." },
    { "type": "text", "id": "button_label", "label": "Texto botón", "default": "Ver productos" },
    { "type": "url", "id": "button_link", "label": "Enlace botón" }
  ],
  "presets": [{ "name": "MS100 Hero" }]
}
{% endschema %}
